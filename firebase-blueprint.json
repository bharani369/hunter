{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item/clothing style available in the collection.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique product identifier" },
        "name": { "type": "string", "description": "Product title" },
        "description": { "type": "string", "description": "Brief product information" },
        "category": { "type": "string", "description": "Product category e.g. Shirts, Hoodies" },
        "price": { "type": "number", "description": "Discounted selling price" },
        "originalPrice": { "type": "number", "description": "Original raw price" },
        "discount": { "type": "number", "description": "Discount percentage" },
        "stock": { "type": "number", "description": "Units available in stock" },
        "rating": { "type": "number", "description": "Average review rating" },
        "reviews": { "type": "number", "description": "Review count" },
        "sizes": { "type": "array", "description": "Available size variables" },
        "tag": { "type": "string", "description": "Promotional or stock label" },
        "image": { "type": "string", "description": "Main product image asset URL" }
      },
      "required": ["id", "name", "category", "price", "originalPrice", "discount", "image"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User details and custom profile settings including loyalty program points.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string", "description": "First name of the user" },
        "lastName": { "type": "string", "description": "Last name of the user" },
        "phone": { "type": "string", "description": "Contact number" },
        "email": { "type": "string", "description": "Email address" },
        "gender": { "type": "string", "description": "Male or female gender selection", "enum": ["male", "female", ""] },
        "loyaltyPoints": { "type": "number", "description": "Accumulated loyalty points" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "ISO timestamp of last update" }
      },
      "required": ["firstName", "lastName", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Real-time purchase order placed by a customer.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the logged-in user who placed the order" },
        "items": { "type": "array", "description": "List of ordered clothing items with sizes and options" },
        "totalAmount": { "type": "number", "description": "Total order pricing" },
        "status": { "type": "string", "description": "Shipping and fulfillment status", "enum": ["Ordered", "Shipped - In Transit", "Out for Delivery", "Delivered", "Cancelled"] },
        "datePlaced": { "type": "string", "format": "date-time", "description": "ISO timestamp of creation" },
        "expectedText": { "type": "string", "description": "Estimated delivery notice string" }
      },
      "required": ["userId", "items", "totalAmount", "status", "datePlaced"]
    },
    "Review": {
      "title": "Review",
      "description": "User feedback and rating for a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique review identifier" },
        "productId": { "type": "string", "description": "The associated product identifier" },
        "productName": { "type": "string", "description": "Name of the product for display in admin panel" },
        "userId": { "type": "string", "description": "UID of the user who wrote the review" },
        "author": { "type": "string", "description": "Display name of the reviewer" },
        "text": { "type": "string", "description": "Detailed review thoughts" },
        "rating": { "type": "number", "description": "Star rating out of 5" },
        "date": { "type": "string", "description": "Month Year display date e.g. Jun 2026" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Technical creation time" }
      },
      "required": ["id", "productId", "text", "rating", "author"]
    }
  },
  "firestore": {
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product ratings and reviews contributed by users."
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Stock of clothes and products synchronized with frontend"
    },
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Custom user profile details and accumulated loyalty program points."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order history records managed by admin dashboard."
    }
  }
}
