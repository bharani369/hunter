rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all default deny safety-net
    match /{document=**} {
      allow read, write: if false;
    }

    // Products collection: visible to everyone for browsing, writable for admin and stock updates
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // Users collection: personal profile, only the authenticated owner can view or edit
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Orders collection: visible to everyone for get & list, writable for admin updates
    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow get, list: if true;
      allow update, delete: if true;
    }
  }
}
